---
import { getEntry } from 'astro:content';

interface Props {
  slug: string;
  num: string;
}

const { slug, num } = Astro.props;
const brief = await getEntry('work', slug);
---
{brief && !brief.data.draft && (
  <>
    <div class="section-h">
      <span class="num">{num}</span>
      <h2><svg class="icon"><use href="#i-brief"/></svg> Featured brief</h2>
      <span class="aside">UX, strategy, and agentic delivery on one engagement.</span>
    </div>

    <a href={`/work/${brief.id}`} class="featured-brief">
      <span class="fb-text">
        <span class="fb-title">{brief.data.title}</span>
        {brief.data.sub && <span class="fb-sub">{brief.data.sub}</span>}
        <span class="fb-meta">
          {brief.data.sector} · {brief.data.role} · {brief.data.duration}
        </span>
        <span class="fb-read">
          <svg class="icon sm"><use href="#i-arrow-right"/></svg> Read the brief
        </span>
      </span>
      <span class="fb-figure">
        <img src="/images/work/agentic-analytics-platform/hero.png" alt="Brand Pulse daily brief interface with one surfaced signal, an ask-the-data input, and at-a-glance metrics. Mock data." loading="lazy" />
      </span>
    </a>

    <a href="/work" class="fb-all">
      <svg class="icon sm"><use href="#i-arrow-right"/></svg> All briefs
    </a>
  </>
)}

<style>
  .featured-brief {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 36px;
    align-items: center;
    padding: 30px 32px;
    border: 1px solid var(--rule);
    border-radius: 4px;
    background: var(--paper-warm);
    transition: border-color 250ms cubic-bezier(0.4, 0, 0.2, 1), transform 250ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .featured-brief:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 6px 24px -12px rgba(20, 24, 29, 0.18);
  }
  .fb-text { display: block; }
  .fb-title {
    display: block;
    font-family: var(--display);
    font-weight: 450;
    font-variation-settings: "opsz" 36, "SOFT" 20;
    font-size: 27px;
    line-height: 1.18;
    letter-spacing: -0.012em;
    color: var(--ink);
    margin-bottom: 12px;
  }
  .fb-sub {
    display: block;
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 58ch;
    margin-bottom: 14px;
  }
  .fb-meta {
    display: block;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 18px;
  }
  .fb-read {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
  }
  .featured-brief:hover .fb-read { color: var(--accent); }
  .fb-figure {
    display: block;
    overflow: hidden;
    border: 1px solid var(--rule);
    border-radius: 4px;
  }
  .fb-figure img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 11;
    object-fit: cover;
    object-position: top;
  }
  .fb-all {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 20px 0 48px;
    font-size: 13px;
    color: var(--ink-faint);
  }
  @media (max-width: 720px) {
    .featured-brief {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
