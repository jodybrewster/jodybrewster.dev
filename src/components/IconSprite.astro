---
---
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <!-- pen tool / mark -->
    <symbol id="i-mark" viewBox="0 0 24 24"><path d="M12 2 L19 9 L12 16 L5 9 Z M12 16 L12 22"/></symbol>
    <!-- book-open (writing) -->
    <symbol id="i-book" viewBox="0 0 24 24"><path d="M2 4h7a3 3 0 0 1 3 3v14a2 2 0 0 0-2-2H2zM22 4h-7a3 3 0 0 0-3 3v14a2 2 0 0 1 2-2h8z"/></symbol>
    <!-- sticky-note -->
    <symbol id="i-note" viewBox="0 0 24 24"><path d="M15.5 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.5z M15 3v6h6"/></symbol>
    <!-- briefcase -->
    <symbol id="i-brief" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></symbol>
    <!-- terminal / agent -->
    <symbol id="i-terminal" viewBox="0 0 24 24"><path d="M4 17l6-6-6-6 M12 19h8"/></symbol>
    <!-- message-circle -->
    <symbol id="i-chat" viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/></symbol>
    <!-- arrow-left -->
    <symbol id="i-arrow-left" viewBox="0 0 24 24"><path d="M19 12H5 M12 19l-7-7 7-7"/></symbol>
    <!-- arrow-right -->
    <symbol id="i-arrow-right" viewBox="0 0 24 24"><path d="M5 12h14 M12 5l7 7-7 7"/></symbol>
    <!-- arrow-up -->
    <symbol id="i-arrow-up" viewBox="0 0 24 24"><path d="M12 19V5 M5 12l7-7 7 7"/></symbol>
    <!-- calendar -->
    <symbol id="i-calendar" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4 M8 2v4 M3 10h18"/></symbol>
    <!-- clock -->
    <symbol id="i-clock" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></symbol>
    <!-- tag -->
    <symbol id="i-tag" viewBox="0 0 24 24"><path d="M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z M7 7h.01"/></symbol>
    <!-- hash -->
    <symbol id="i-hash" viewBox="0 0 24 24"><path d="M4 9h16 M4 15h16 M10 3 8 21 M16 3l-2 18"/></symbol>
    <!-- send -->
    <symbol id="i-send" viewBox="0 0 24 24"><path d="m22 2-7 20-4-9-9-4z M22 2 11 13"/></symbol>
    <!-- search -->
    <symbol id="i-search" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></symbol>
    <!-- sparkles -->
    <symbol id="i-sparkle" viewBox="0 0 24 24"><path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3z"/></symbol>
    <!-- link external -->
    <symbol id="i-external" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6 M15 3h6v6 M10 14 21 3"/></symbol>
    <!-- check -->
    <symbol id="i-check" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></symbol>
    <!-- copy -->
    <symbol id="i-copy" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></symbol>
    <!-- code -->
    <symbol id="i-code" viewBox="0 0 24 24"><path d="m16 18 6-6-6-6 M8 6l-6 6 6 6"/></symbol>
    <!-- compass -->
    <symbol id="i-compass" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="m16.24 7.76-2.12 6.36-6.36 2.12 2.12-6.36z"/></symbol>
    <!-- layers -->
    <symbol id="i-layers" viewBox="0 0 24 24"><path d="m12 2 10 6-10 6L2 8z M2 16l10 6 10-6 M2 12l10 6 10-6"/></symbol>
    <!-- chevron-right -->
    <symbol id="i-chev-right" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></symbol>
    <!-- circle-dot -->
    <symbol id="i-dot" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3" fill="currentColor"/></symbol>
    <!-- rss -->
    <symbol id="i-rss" viewBox="0 0 24 24"><path d="M4 11a9 9 0 0 1 9 9 M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1" fill="currentColor"/></symbol>
    <!-- mail -->
    <symbol id="i-mail" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></symbol>
    <!-- shield-check -->
    <symbol id="i-shield" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z M9 12l2 2 4-4"/></symbol>
    <!-- file-text -->
    <symbol id="i-file" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8"/></symbol>
    <!-- bot -->
    <symbol id="i-bot" viewBox="0 0 24 24"><rect x="3" y="8" width="18" height="12" rx="2"/><path d="M12 2v4 M8 14h.01 M16 14h.01 M9 18h6"/></symbol>
    <!-- eye -->
    <symbol id="i-eye" viewBox="0 0 24 24"><path d="M2 12s4-8 10-8 10 8 10 8-4 8-10 8-10-8-10-8z"/><circle cx="12" cy="12" r="3"/></symbol>
    <!-- quote -->
    <symbol id="i-quote" viewBox="0 0 24 24"><path d="M3 21c3 0 7-1 7-8V5a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h3 M15 21c3 0 7-1 7-8V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h3"/></symbol>
    <!-- bar-chart -->
    <symbol id="i-bar" viewBox="0 0 24 24"><path d="M12 20V10 M18 20V4 M6 20v-6"/></symbol>
    <!-- briefcase-business / sector -->
    <symbol id="i-building" viewBox="0 0 24 24"><rect x="4" y="2" width="16" height="20" rx="1"/><path d="M9 22v-4h6v4 M8 6h.01 M16 6h.01 M12 6h.01 M8 10h.01 M12 10h.01 M16 10h.01 M8 14h.01 M12 14h.01 M16 14h.01"/></symbol>
    <!-- user -->
    <symbol id="i-user" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 22a8 8 0 1 1 16 0"/></symbol>
    <!-- target -->
    <symbol id="i-target" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2" fill="currentColor"/></symbol>
    <!-- trending-down -->
    <symbol id="i-trend-down" viewBox="0 0 24 24"><path d="m22 17-8.5-8.5-5 5L2 7 M16 17h6v-6"/></symbol>
    <!-- gauge -->
    <symbol id="i-gauge" viewBox="0 0 24 24"><path d="M12 14 8 10 M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4 M5 19a10 10 0 1 1 14 0"/></symbol>
    <!-- zap -->
    <symbol id="i-zap" viewBox="0 0 24 24"><path d="M13 2 3 14h9l-1 8 10-12h-9z"/></symbol>
  </defs>
</svg>
