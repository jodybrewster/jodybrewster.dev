---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import IconSprite from '../components/IconSprite.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ChatDock from '../components/ChatDock.astro';
import { flags } from '../lib/flags';

interface Props {
  title: string;
  description?: string;
  jsonLd?: Record<string, unknown>;
  markdownHref?: string;
  bodyClass?: string;
}

const { title, description, jsonLd, markdownHref, bodyClass } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="light dark" />
  <title>{title}</title>
  <!-- Anti-FOUC: apply stored theme before first paint -->
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('theme');
      if (stored === 'dark' || stored === 'light') {
        document.documentElement.setAttribute('data-theme', stored);
      }
    })();
  </script>
  {description && <meta name="description" content={description} />}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!-- Display: Fraunces (editorial serif w/ optical sizing). Body/UI: Inter (workhorse sans). Mono: JetBrains Mono. -->
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..600,30..100;1,9..144,300..600,30..100&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  {markdownHref && (
    <link rel="alternate" type="text/markdown" href={markdownHref} />
  )}

  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  <ClientRouter />
</head>
<body class={bodyClass}>
  <IconSprite />
  <div class="shell">
    <Nav />
    <slot />
    <Footer />
  </div>
  {flags.chat && <ChatDock />}
</body>
</html>
