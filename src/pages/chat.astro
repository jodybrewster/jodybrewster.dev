---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import { flags } from '../lib/flags';

if (!flags.chat) return Astro.redirect('/');
---
<Base
  title="Ask the site — Jody Brewster"
  description="A chat interface over Jody Brewster's published essays, notes, and case briefs. Speaks in third person, cites its sources, refuses what isn't in the corpus."
>
  <main class="page active" style="padding: 72px 0 100px;">
    <PageHeader
      icon="i-chat"
      eyebrow="Ask the site"
      title="Ask the site."
      description="A chat interface on the site of someone who has argued that chat is a bad UI for AI. The contradiction is the point."
    />

    <div class="chat-explainer">
      <p>The ask bar at the bottom of every page is the chat. It speaks <em>about</em> Jody in the third person, cites its sources, and refuses questions outside what he has published. It will sometimes be wrong, so the cited essays are the source of truth, not the synthesis above them.</p>
      <p>Type a question below, anywhere on the site.</p>
    </div>
  </main>
</Base>

<style>
  .chat-explainer {
    max-width: 62ch;
  }
  .chat-explainer p {
    font-family: var(--sans);
    font-size: 16.5px;
    line-height: 1.7;
    color: var(--ink-soft);
    margin: 0 0 18px;
  }
  .chat-explainer em {
    font-family: var(--display);
    font-style: italic;
    font-variation-settings: "opsz" 14, "SOFT" 20;
    color: var(--ink);
  }
</style>
