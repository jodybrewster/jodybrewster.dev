---
import { getCollection } from 'astro:content';
import { readFile } from 'node:fs/promises';
import { resolve } from 'node:path';
import Base from '../layouts/Base.astro';
import EssayCard from '../components/EssayCard.astro';
import NoteCard from '../components/NoteCard.astro';
import FeaturedBrief from '../components/FeaturedBrief.astro';

const essays = (await getCollection('writing', e => e.data.status === 'published'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const research = (await getCollection('research', r => r.data.publish))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const notes = (await getCollection('notes', n => n.data.publish))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const hasWriting = essays.length > 0;
const recentEssays = essays.slice(0, 5);
const recentResearch = research.slice(0, 5);
const recentNotes = notes.slice(0, 4);

const nowRaw = await readFile(resolve('content/now.md'), 'utf-8');
const fmMatch = nowRaw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
const nowFrontmatter: Record<string, string> = fmMatch
  ? Object.fromEntries(
      fmMatch[1].split('\n').filter(Boolean).map(line => {
        const idx = line.indexOf(':');
        const k = line.slice(0, idx).trim();
        const v = line.slice(idx + 1).trim().replace(/^["']|["']$/g, '');
        return [k, v];
      })
    )
  : {};
const nowContent = fmMatch ? fmMatch[2] : nowRaw;
const nowLines = nowContent.trim().split('\n').filter(Boolean).slice(0, 4);
const nowUpdated = nowFrontmatter.updated
  ? new Date(nowFrontmatter.updated).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
  : '';

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function readTime(body: string) {
  const words = body.split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.ceil(words / 200))} min`;
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://jodybrewster.dev/#website',
      url: 'https://jodybrewster.dev/',
      name: 'Jody Brewster',
      description: 'Jody Brewster is an AI experience architect - designer, product thinker, builder. Shipping agentic products end to end.',
      inLanguage: 'en',
      publisher: { '@id': 'https://jodybrewster.dev/#person' },
    },
    {
      '@type': 'Person',
      '@id': 'https://jodybrewster.dev/#person',
      name: 'Jody Brewster',
      url: 'https://jodybrewster.dev/',
      jobTitle: 'AI Experience Architect',
      sameAs: [
        'https://github.com/jodybrewster',
        'https://www.linkedin.com/in/jodybrewster',
        'https://www.behance.net/jodybrewster',
      ],
      knowsAbout: [
        'AI experience architecture',
        'Agentic systems',
        'Runtime design',
        'Evaluation as design',
      ],
    },
  ],
};
---
<Base
  title="Jody Brewster"
  description="Jody Brewster is an AI experience architect - designer, product thinker, builder. Shipping agentic products end to end."
  jsonLd={jsonLd}
>
  <main class="page active">

    <section class="hero">
      <p class="eyebrow role-label">
        <span class="dot"></span>
        Agency craft, agentic systems
      </p>
      <h1>AI experience architect, designer, <em>product thinker</em>, builder.</h1>
      <p class="lede">I figure out what to build and then build it - interface, strategy, and runtime in one pass. What used to take a department now takes me a sprint.</p>
      <div class="meta">
        {nowUpdated && <span><i class="pulse"></i> recently tended · {nowUpdated}</span>}
        {hasWriting
          ? <span><svg class="icon sm"><use href="#i-book"/></svg> {essays.length} essays</span>
          : <span><svg class="icon sm"><use href="#i-compass"/></svg> {research.length} research</span>
        }
        <span><svg class="icon sm"><use href="#i-note"/></svg> {notes.length} {notes.length === 1 ? 'note' : 'notes'}</span>
      </div>
    </section>

    <FeaturedBrief slug="agentic-analytics-platform" num="§ 01" />

    {hasWriting ? (
      <>
        <div class="section-h">
          <span class="num">§ 02</span>
          <h2><svg class="icon"><use href="#i-book"/></svg> Recent writing</h2>
          <span class="aside">Essays, in order of having been finished.</span>
        </div>
        <ul class="essay-list">
          {recentEssays.map((essay, i) => (
            <EssayCard
              title={essay.data.title}
              date={formatDate(essay.data.date)}
              description={essay.data.description}
              tags={essay.data.tags}
              slug={essay.id}
              index={`№ ${String(essays.length - i).padStart(3, '0')}`}
              readTime={readTime(essay.body ?? '')}
            />
          ))}
        </ul>
        <a href="/writing" style="display:inline-flex;align-items:center;gap:6px;margin-bottom:48px;font-size:13px;color:var(--ink-faint);">
          <svg class="icon sm"><use href="#i-arrow-right"/></svg> All writing
        </a>
      </>
    ) : (
      <>
        <div class="section-h">
          <span class="num">§ 02</span>
          <h2><svg class="icon"><use href="#i-compass"/></svg> Recent research</h2>
          <span class="aside">Landscape scans and working maps from my second brain, reviewed before they ship.</span>
        </div>
        <ul class="essay-list">
          {recentResearch.map((entry, i) => (
            <EssayCard
              title={entry.data.title}
              date={formatDate(entry.data.pubDate)}
              description={entry.data.description}
              tags={entry.data.tags}
              slug={entry.id}
              basePath="/research"
              index={`№ ${String(research.length - i).padStart(3, '0')}`}
              readTime={readTime(entry.body ?? '')}
            />
          ))}
        </ul>
        <a href="/research" style="display:inline-flex;align-items:center;gap:6px;margin-bottom:48px;font-size:13px;color:var(--ink-faint);">
          <svg class="icon sm"><use href="#i-arrow-right"/></svg> All research
        </a>
      </>
    )}

    <div class="two-col">
      <div>
        <div class="section-h">
          <span class="num">§ 03</span>
          <h2><svg class="icon"><use href="#i-note"/></svg> Notes</h2>
          <span class="aside">Shorter, less finished, sometimes wrong.</span>
        </div>
        <div class="notes-stack">
          {recentNotes.map((note) => {
            const excerpt = (note.body ?? '').split('\n').find(l => l.trim() && !l.startsWith('#')) ?? '';
            return (
              <NoteCard
                title={note.data.title}
                date={formatDate(note.data.date)}
                status={note.data.status}
                slug={note.id}
                tags={note.data.tags}
                body={excerpt.slice(0, 200)}
              />
            );
          })}
        </div>
        <a href="/notes" style="display:inline-flex;align-items:center;gap:6px;margin-top:16px;font-size:13px;color:var(--ink-faint);">
          <svg class="icon sm"><use href="#i-arrow-right"/></svg> All notes
        </a>
      </div>

      <aside class="now-panel">
        <p class="eyebrow label">/ now{nowUpdated && ` · ${nowUpdated}`}</p>
        <h4><svg class="icon"><use href="#i-compass"/></svg> What I'm thinking about</h4>
        <ul>
          {nowLines.map(line => (
            <li><svg class="icon sm li-icon"><use href="#i-file"/></svg> {line.replace(/^[-*]\s*/, '')}</li>
          ))}
        </ul>
        <p class="stamp"><a href="/now">Read more →</a></p>
      </aside>
    </div>

  </main>
</Base>
