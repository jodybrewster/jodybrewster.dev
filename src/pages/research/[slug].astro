---
import { getCollection, getEntry, render } from 'astro:content';
import Essay from '../../layouts/Essay.astro';

export async function getStaticPaths() {
  const published = await getCollection('research', r => r.data.publish);
  return published.map((entry) => ({ params: { slug: entry.id } }));
}

const { slug } = Astro.params;
const entry = slug ? await getEntry('research', slug) : undefined;
if (!entry || !entry.data.publish) return new Response('Not found', { status: 404 });

const entries = (await getCollection('research', r => r.data.publish))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const idx = entries.findIndex(e => e.id === entry.id);

const words = (entry.body ?? '').split(/\s+/).filter(Boolean).length;
const readTime = `${Math.max(1, Math.ceil(words / 200))} min`;
const number = String(entries.length - idx).padStart(3, '0');

const { Content } = await render(entry);

const date = entry.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const isoDate = entry.data.pubDate.toISOString();
---
<Essay
  title={entry.data.title}
  description={entry.data.description}
  date={date}
  isoDate={isoDate}
  readTime={readTime}
  tags={entry.data.tags}
  pillar={entry.data.pillar}
  number={number}
  sectionHref="/research"
  sectionLabel="research"
>
  <Content />
</Essay>
