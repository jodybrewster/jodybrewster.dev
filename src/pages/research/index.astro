---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import EssayCard from '../../components/EssayCard.astro';
import PageHeader from '../../components/PageHeader.astro';

const entries = (await getCollection('research', r => r.data.publish))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function readTime(body: string) {
  const words = body.split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.ceil(words / 200))} min`;
}
---
<Base title="Research — Jody Brewster" description="Research notes — landscape scans, tool comparisons, and working maps of AI design and agentic systems.">
  <main class="page active" style="padding: 72px 0 100px;">
    <PageHeader
      icon="i-compass"
      eyebrow={`${entries.length} ${entries.length === 1 ? 'piece' : 'pieces'}`}
      title="Research"
      description="Landscape scans and working maps. Researched by Claude under my direction; I review everything before it ships. Surfacing what my second brain is building on is part of the point."
    />

    <ul class="essay-list">
      {entries.map((entry, i) => (
        <EssayCard
          title={entry.data.title}
          date={formatDate(entry.data.pubDate)}
          description={entry.data.description}
          tags={entry.data.tags}
          slug={entry.id}
          basePath="/research"
          index={`№ ${String(entries.length - i).padStart(3, '0')}`}
          readTime={readTime(entry.body ?? '')}
        />
      ))}
    </ul>
  </main>
</Base>
