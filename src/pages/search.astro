---
import Base from '../layouts/Base.astro';
---
<Base title="Search — Jody Brewster" description="Full-text search across writing, notes, and work.">
  <main class="page active" style="padding: 72px 0 100px;">
    <div class="section-h" style="margin-top:0;">
      <h2><svg class="icon"><use href="#i-search"/></svg> Search</h2>
      <span class="aside">Full-text across writing, notes, and work.</span>
    </div>

    <div style="max-width:660px;">
      <div id="search"></div>
      <p id="search-fallback" class="aside" style="display:none; margin-top:18px;">
        Search index is only generated by the production build. Run <code>npm run build &amp;&amp; npm run preview</code> to try it locally.
      </p>
    </div>
  </main>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script src="/pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (window.PagefindUI) {
        new window.PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          excerptLength: 30,
          processTerm: (term) => term.toLowerCase(),
        });
      } else {
        document.getElementById('search-fallback').style.display = 'block';
      }
    });
  </script>

  <style>
    .pagefind-ui {
      --pagefind-ui-primary: var(--accent);
      --pagefind-ui-text: var(--ink);
      --pagefind-ui-background: var(--paper);
      --pagefind-ui-border: var(--paper-warm);
      --pagefind-ui-tag: var(--paper-warm);
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 6px;
      --pagefind-ui-font: var(--sans, 'Inter', system-ui, sans-serif);
    }
    .pagefind-ui .pagefind-ui__search-input {
      background: var(--paper-warm);
      color: var(--ink);
      border-color: var(--paper-warm);
      font-family: var(--sans, 'Inter', system-ui, sans-serif);
    }
    .pagefind-ui .pagefind-ui__search-input:focus {
      border-color: var(--accent);
      outline: none;
    }
    .pagefind-ui .pagefind-ui__result-title a {
      color: var(--ink);
      border-bottom: none;
    }
    .pagefind-ui .pagefind-ui__result-title a:hover { color: var(--accent); }
    .pagefind-ui .pagefind-ui__result-excerpt { color: var(--ink-soft); }
    .pagefind-ui mark {
      background: var(--accent-soft);
      color: var(--accent);
      padding: 0 2px;
      border-radius: 2px;
    }
    .pagefind-ui .pagefind-ui__message { color: var(--ink-faint); }
  </style>
</Base>
