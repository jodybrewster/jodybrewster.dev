---
import { getCollection, getEntry, render } from 'astro:content';
import Essay from '../../layouts/Essay.astro';

const { slug } = Astro.params;
const entry = slug ? await getEntry('writing', slug) : undefined;
if (!entry || entry.data.status === 'draft') return new Response('Not found', { status: 404 });

const essays = (await getCollection('writing', e => e.data.status === 'published'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const idx = essays.findIndex(e => e.id === entry.id);

const words = (entry.body ?? '').split(/\s+/).filter(Boolean).length;
const readTime = `${Math.max(1, Math.ceil(words / 200))} min`;
const number = String(essays.length - idx).padStart(3, '0');

const { Content } = await render(entry);

const date = entry.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const isoDate = entry.data.date.toISOString();
---
<Essay
  title={entry.data.title}
  description={entry.data.description}
  date={date}
  isoDate={isoDate}
  readTime={readTime}
  tags={entry.data.tags}
  pillar={entry.data.pillar}
  number={number}
>
  <Content />
</Essay>
